{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git remote -v)",
      "Bash(git ls-files*)",
      "Bash(git stash list*)",
      "Bash(git stash show*)",
      "Bash(git blame*)",
      "Bash(git config --get*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-remote*)",
      "Bash(git describe*)",

      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",

      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run typecheck*)",
      "Bash(npm test)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm typecheck*)",
      "Bash(yarn lint*)",
      "Bash(yarn test*)",

      "Bash(pytest*)",
      "Bash(uv run pytest*)",
      "Bash(uv run --quiet pytest*)",
      "Bash(uv run ruff*)",
      "Bash(uv run --quiet ruff*)",
      "Bash(uv run mypy*)",
      "Bash(ruff check*)",
      "Bash(ruff format --check*)",
      "Bash(mypy*)",
      "Bash(poetry run pytest*)",
      "Bash(poetry run ruff*)",
      "Bash(poetry run mypy*)",

      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(go build ./...)",
      "Bash(cargo check*)",
      "Bash(cargo clippy*)",
      "Bash(cargo test*)",

      "Bash(make help)",
      "Bash(make lint*)",
      "Bash(make test*)",
      "Bash(make typecheck*)",
      "Bash(make verify*)",
      "Bash(make check*)",

      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(file *)",
      "Bash(tree *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf .git*)",
      "Bash(git push --force*)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git push --force-with-lease origin master*)"
    ]
  }
}
